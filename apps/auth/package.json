{
  "name": "@my-auth/auth",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:ci": "vitest run --coverage",
    "test:coverage": "vitest run --coverage && open coverage/lcov-report/index.html",
    "docker:build": "docker build -t my-auth-app .",
    "docker:run": "docker run -d -p 8080:80 --name auth-container my-auth-app",
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "docs:generate": "ts-node scripts/generate-docs.ts",
    "docs:dev": "npm run docs:generate && vitepress dev docs",
    "docs:build": "npm run docs:generate && vitepress build docs",
    "api:generate": "hey-api -c scripts/hey-api.config.ts",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxlint --fix",
    "format:write": "oxlint --fix",
    "docs:user": "typedoc",
    "docs:watch": "typedoc --watch"
  },
  "dependencies": {
    "@sentry/browser": "^10.49.0",
    "@sentry/core": "^10.49.0",
    "@sentry/tracing": "^7.120.4",
    "@sentry/vue": "^10.50.0",
    "@tanstack/query-sync-storage-persister": "^5.99.0",
    "@tanstack/vue-query": "^5.96.2",
    "@tatymusaeva/orbitto": "^1.0.4",
    "axios": "^1.15.1",
    "pinia": "^2.1.7",
    "pinia-plugin-persistedstate": "^4.7.1",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@hey-api/openapi-ts": "^0.96.0",
    "@lumirelle/oxlint-config": "^0.2.2",
    "@testing-library/vue": "^8.1.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vuese/parser": "^2.10.3",
    "cross-env": "^10.1.0",
    "jsdom": "^29.0.2",
    "msw": "^2.14.2",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.5",
    "vitepress": "^1.6.4",
    "vitest": "^4.1.3",
    "vue-component-meta": "^3.2.6",
    "vue-tsc": "^2.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
